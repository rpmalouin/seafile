version: "3.9"

networks:
  seafile-net:
    name: seafile-net
    external: false
  caddy-net:
    name: caddy-net
    external: false

services:
  db:
    image: mariadb:10.11
    container_name: seafile-mysql
    restart: unless-stopped
    ports:
      - "3307:3306"
    environment:
      - MYSQL_ROOT_PASSWORD=CHANGE_ME
      - MYSQL_LOG_CONSOLE=true
      - MARIADB_AUTO_UPGRADE=1
    volumes:
      - ./db:/var/lib/mysql
    networks:
      - seafile-net
    healthcheck:
      test: ["CMD", "/usr/local/bin/healthcheck.sh", "--connect", "--mariadbupgrade", "--innodb_initialized"]
      interval: 20s
      start_period: 30s
      timeout: 5s
      retries: 10

  redis:
    image: redis:7-alpine
    container_name: seafile-redis
    restart: unless-stopped
    command: >
      /bin/sh -c "redis-server --requirepass \"$REDIS_PASSWORD\""
    environment:
      - REDIS_PASSWORD=CHANGE_ME
    networks:
      - seafile-net

  memcached:
    image: memcached:1.6-alpine
    container_name: seafile-memcached
    restart: unless-stopped
    command: memcached -m 256
    networks:
      - seafile-net

  caddy:
    image: caddy:2-alpine
    container_name: seafile-caddy
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
      - "8085:8085"
    volumes:
      - ./caddy/Caddyfile:/etc/caddy/Caddyfile
      - ./caddy/data:/data
      - ./caddy/config:/config
    networks:
      - caddy-net

  seadoc:
    image: seafileltd/sdoc-server:2.0.9
    container_name: seadoc
    restart: unless-stopped
    volumes:
      - ./seadoc-data:/shared
    environment:
      - DB_HOST=db
      - DB_USER=seafile
      - DB_PASSWORD=CHANGE_ME
      - DB_NAME=seahub_db
      - TIME_ZONE=UTC
      - JWT_PRIVATE_KEY=CHANGE_ME
      - SEAFILE_SERVER_HOSTNAME=example.com
      - SEAFILE_SERVER_PROTOCOL=https
      - SEAHUB_SERVICE_URL=http://seafile:80
    ports:
      - "7070:7070"
    depends_on:
      - db
      - seafile
    networks:
      - seafile-net
      - caddy-net

  seafile:
    image: seafileltd/seafile-mc:13.0.24
    container_name: seafile
    restart: unless-stopped
    extra_hosts:
      - "host.docker.internal:host-gateway"
    volumes:
      - ./seafile-data:/shared
    environment:
      - SEAFILE_MYSQL_DB_HOST=db
      - SEAFILE_MYSQL_DB_PORT=3306
      - SEAFILE_MYSQL_DB_USER=seafile
      - SEAFILE_MYSQL_DB_PASSWORD=CHANGE_ME
      - INIT_SEAFILE_MYSQL_ROOT_PASSWORD=CHANGE_ME
      - SEAFILE_MYSQL_DB_CCNET_DB_NAME=ccnet_db
      - SEAFILE_MYSQL_DB_SEAFILE_DB_NAME=seafile_db
      - SEAFILE_MYSQL_DB_SEAHUB_DB_NAME=seahub_db
      - TIME_ZONE=UTC
      - INIT_SEAFILE_ADMIN_EMAIL=admin@example.com
      - INIT_SEAFILE_ADMIN_PASSWORD=CHANGE_ME
      - SEAFILE_SERVER_HOSTNAME=example.com
      - SEAFILE_SERVER_PROTOCOL=https
      - SITE_ROOT=/
      - NON_ROOT=false
      - JWT_PRIVATE_KEY=CHANGE_ME
      - SEAFILE_LOG_TO_STDOUT=true
      - ENABLE_GO_FILESERVER=true
      - ENABLE_SEADOC=true
      - SEADOC_SERVER_URL=http://seadoc:7070
      - CACHE_PROVIDER=memcached
      - REDIS_HOST=redis
      - REDIS_PORT=6379
      - REDIS_PASSWORD=CHANGE_ME
      - MEMCACHED_HOST=memcached
      - MEMCACHED_PORT=11211
      - ENABLE_NOTIFICATION_SERVER=true
      - ENABLE_SEAFILE_AI=false
      - ENABLE_FACE_RECOGNITION=false
      - SEAFILE_AI_SERVER_URL=
      - SEAFILE_AI_SECRET_KEY=
      - MD_FILE_COUNT_LIMIT=5000
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_started
    networks:
      - seafile-net
      - caddy-net

  onlyoffice:
    image: onlyoffice/documentserver:latest
    container_name: onlyoffice-documentserver
    restart: unless-stopped
    environment:
      - JWT_ENABLED=true
      - JWT_SECRET=CHANGE_ME
    volumes:
      - ./onlyoffice/data:/var/www/onlyoffice/Data
      - ./onlyoffice/logs:/var/log/onlyoffice
    networks:
      - caddy-net
